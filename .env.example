# Enquiry Storage Configuration
# Set ENQUIRY_STORAGE_PROVIDER to google-apps-script to save submissions into Google Sheets via Apps Script.
# Leave it as auto to prefer Apps Script when configured, then Google Sheets, then email.
ENQUIRY_STORAGE_PROVIDER=auto
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/your_web_app_id/exec
GOOGLE_APPS_SCRIPT_SHARED_SECRET=your_shared_secret
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheet_id
GOOGLE_SHEETS_SHEET_NAME=Enquiries
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_BASE64=base64_encoded_private_key

# Email Delivery Configuration
# Set EMAIL_PROVIDER to sendgrid or brevo. Leave as auto to infer from the key you provide.
EMAIL_PROVIDER=auto
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# BREVO_API_KEY=xkeysib-your_brevo_api_key_here
CONTACT_TO_EMAIL=promaterialuk@gmail.com
CONTACT_FROM_EMAIL=promaterialuk@gmail.com
ENQUIRY_SECTION_ENABLED=true

# Deployment Configuration
# NETLIFY_SITE_ID=your_netlify_site_id
# NETLIFY_AUTH_TOKEN=your_netlify_auth_token

# Or if using Vercel:
# VERCEL_PROJECT_ID=your_vercel_project_id
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_TOKEN=your_vercel_token

# Domain Configuration
PRIMARY_DOMAIN=promaterial.co.uk
